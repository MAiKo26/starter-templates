# Server
PORT=8000
NODE_ENV=development

# Logging
LOG_LEVEL=DEBUG
LOG_PRETTY=true

# Database (must match docker-compose.yml postgres credentials)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/starter

# Connection pool
PG_POOL_MAX=10
PG_POOL_MIN=1

# CORS (comma-separated origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Auth (Better Auth)
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE_SECONDS=604800
BETTER_AUTH_SECRET=replace-with-at-least-32-characters-secret-here-now
BETTER_AUTH_URL=http://localhost:8000

# MinIO / S3 (must match docker-compose.yml minio credentials)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=starter-blobs
MINIO_SECURE=false

# Redis
REDIS_URL=redis://localhost:6379

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
